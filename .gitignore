# Ignore virtual environment folder entirely
.venv/

# Ignore environment variables file
.env

# Byte-compiled / cache files
__pycache__/
*.py[cod]

# OS/IDE specific files
.DS_Store
.idea/
.vscode/

# Logs
*.log

# Streamlit cache (if used)
.streamlit/

# Generated chart files (large HTML files)
app/chainlit/static/charts/*.html

# Chainlit runtime file storage (session-scoped, not source code)
.files/

# Claude Code memory and session data (personal, not project config)
.claude/