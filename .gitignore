# Ignore virtual environment folder entirely
.venv/

# Ignore environment variables file
.env

# Byte-compiled / cache files
__pycache__/
*.py[cod]

# OS/IDE specific files
.DS_Store
.idea/
.vscode/

# Logs
*.log

# Streamlit cache (if used)
.streamlit/

# Generated chart files (large HTML files)
app/chainlit/static/charts/*.html

# Chainlit runtime file storage (session-scoped, not source code)
.files/

# Claude Code memory and session data (personal, not project config)
.claude/

# Superpowers planning artifacts (specs and plans are working docs, not codebase artifacts)
docs/superpowers/

# ChromaDB vector store (runtime-generated embeddings, rebuilt on first run)
data/

# Pytest coverage artifact
.coverage
.coverage.*
htmlcov/

# Chainlit auto-generated i18n translation files (regenerated at startup)
.chainlit/translations/

# Claude Code session logs (personal, not project config)
.remember/

# Salesforce DX (unrelated tooling — not part of this project)
.sfdx/

# Playwright MCP browser session logs and snapshots (Claude Code runtime artifacts)
.playwright-mcp/

# Firecrawl session artifacts (research scratch data, not source code)
.firecrawl/